{% comment %}Hero Section — Brutalista NANO v3.0{% endcomment %}

<section class="hero" data-section-id="{{ section.id }}">
  <div class="hero__box">
    <h1 class="hero__title">
      {%- if section.settings.title != blank -%}
        {{ section.settings.title }}
      {%- else -%}
        HARDWARE<br>SIN FRICCIÓN.
      {%- endif -%}
    </h1>

    <div class="hero__subtitle">
      {%- if section.settings.subtitle != blank -%}
        {%- assign lines = section.settings.subtitle | newline_to_br | split: '<br />' -%}
        {%- for line in lines -%}
          {%- assign clean_line = line | strip_html | strip -%}
          {%- if clean_line != blank -%}
            <p>{{ clean_line }}</p>
          {%- endif -%}
        {%- endfor -%}
      {%- else -%}
        <p>Inicializando catálogo NANO...</p>
        <p>Herramientas para creadores, desarrolladores y entusiastas.</p>
      {%- endif -%}
    </div>

    <a
      href="{{ section.settings.cta_url | default: '/collections/all' }}"
      class="hero__cta"
    >
      {{ section.settings.cta_label | default: 'EXPLORAR INVENTARIO' }}
      <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M5 12h14M12 5l7 7-7 7"/>
      </svg>
    </a>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "HARDWARE SIN FRICCIÓN."
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtítulo (líneas separadas = líneas terminales)",
      "default": "Inicializando catálogo NANO...\nHerramientas para creadores, desarrolladores y entusiastas."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Texto del botón CTA",
      "default": "EXPLORAR INVENTARIO"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "URL del botón CTA"
    }
  ],
  "presets": [
    {
      "name": "Hero",
      "category": "Hero"
    }
  ]
}
{% endschema %}
