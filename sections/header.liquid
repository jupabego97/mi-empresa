{% comment %}Header — Brutalista NANO v3.0{% endcomment %}

<header class="site-header" role="banner">
  <div class="site-header__left">
    <!-- Hamburger (mobile) -->
    <button class="mobile-menu-btn" aria-label="Abrir menú" aria-controls="mobile-menu" aria-expanded="false">
      <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M3 6h18M3 12h18M3 18h18"/>
      </svg>
    </button>

    <!-- Logo -->
    <a href="/" class="site-header__logo" aria-label="{{ shop.name }}">
      {%- if section.settings.logo != blank -%}
        <img
          src="{{ section.settings.logo | img_url: 'x88' }}"
          alt="{{ shop.name }}"
          width="{{ section.settings.logo_width | default: 120 }}"
          height="44"
          loading="eager"
        >
      {%- else -%}
        <span class="site-header__logo-text">{{ shop.name }}</span>
      {%- endif -%}
    </a>

    <!-- Desktop nav -->
    <nav class="site-header__nav" aria-label="Navegación principal">
      <a href="/" class="site-header__nav-link {% if request.path == '/' %}active{% endif %}">INICIO</a>
      <a href="/collections/all" class="site-header__nav-link {% if request.path contains '/collections' %}active{% endif %}">CATÁLOGO</a>
      {%- if section.settings.whatsapp_number != blank -%}
        <a href="https://wa.me/{{ section.settings.whatsapp_number }}" class="site-header__nav-link" target="_blank" rel="noopener">CONTACTO</a>
      {%- endif -%}
    </nav>
  </div>

  <div class="site-header__actions">
    <!-- Search -->
    <a href="/search" aria-label="Buscar" style="color:var(--color-accent); display:flex;">
      <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
        <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
      </svg>
    </a>

    <!-- Cart toggle -->
    <button class="cart-toggle-btn" aria-label="Abrir carrito" aria-haspopup="dialog">
      <span>CARRITO [<span data-cart-count>{{ cart.item_count }}</span>]</span>
      <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/>
      </svg>
    </button>
  </div>
</header>

<!-- Mobile menu overlay -->
<nav id="mobile-menu" class="mobile-menu" aria-label="Menú móvil" aria-hidden="true">
  <button class="mobile-menu__close" aria-label="Cerrar menú">&times;</button>
  <div class="mobile-menu__nav">
    <a href="/" class="mobile-menu__link">INICIO</a>
    <a href="/collections/all" class="mobile-menu__link">CATÁLOGO</a>
    <a href="/cart" class="mobile-menu__link">CARRITO ({{ cart.item_count }})</a>
    {%- if section.settings.whatsapp_number != blank -%}
      <a href="https://wa.me/{{ section.settings.whatsapp_number }}" class="mobile-menu__link" target="_blank" rel="noopener">CONTACTO</a>
    {%- endif -%}
  </div>
</nav>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "range",
      "id": "logo_width",
      "label": "Ancho del logo (px)",
      "min": 60,
      "max": 260,
      "step": 10,
      "default": 120
    },
    {
      "type": "text",
      "id": "whatsapp_number",
      "label": "Número WhatsApp (sin +)",
      "placeholder": "573001234567"
    }
  ]
}
{% endschema %}
