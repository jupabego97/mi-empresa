{% comment %}Footer — Brutalista NANO v3.0{% endcomment %}

<footer class="site-footer" role="contentinfo" data-section-id="{{ section.id }}">
  <div class="site-footer__inner">
    <p class="site-footer__copy">
      &copy; {{ 'now' | date: '%Y' }} {{ shop.name | upcase }}. TODOS LOS DERECHOS RESERVADOS.
    </p>
    <nav class="site-footer__links" aria-label="Links del pie de página">
      {%- if section.settings.link_1_label != blank -%}
        <a href="{{ section.settings.link_1_url | default: '/policies/privacy-policy' }}" class="site-footer__link">
          {{ section.settings.link_1_label }}
        </a>
      {%- endif -%}
      {%- if section.settings.link_2_label != blank -%}
        <a href="{{ section.settings.link_2_url | default: '/policies/terms-of-service' }}" class="site-footer__link">
          {{ section.settings.link_2_label }}
        </a>
      {%- endif -%}
      {%- if section.settings.link_3_label != blank -%}
        <a href="{{ section.settings.link_3_url | default: '#' }}" class="site-footer__link">
          {{ section.settings.link_3_label }}
        </a>
      {%- endif -%}
      {%- if section.settings.whatsapp_number != blank -%}
        <a href="https://wa.me/{{ section.settings.whatsapp_number }}" class="site-footer__link" target="_blank" rel="noopener">
          WHATSAPP
        </a>
      {%- endif -%}
    </nav>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "text",
      "id": "link_1_label",
      "label": "Link 1 texto",
      "default": "STATUS"
    },
    {
      "type": "url",
      "id": "link_1_url",
      "label": "Link 1 URL"
    },
    {
      "type": "text",
      "id": "link_2_label",
      "label": "Link 2 texto",
      "default": "TÉRMINOS"
    },
    {
      "type": "url",
      "id": "link_2_url",
      "label": "Link 2 URL"
    },
    {
      "type": "text",
      "id": "link_3_label",
      "label": "Link 3 texto",
      "default": "API"
    },
    {
      "type": "url",
      "id": "link_3_url",
      "label": "Link 3 URL"
    },
    {
      "type": "text",
      "id": "whatsapp_number",
      "label": "Número WhatsApp (sin +)",
      "placeholder": "573001234567"
    }
  ]
}
{% endschema %}
